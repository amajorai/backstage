# Polar License Validation

# Environment: "production" or "sandbox"
VITE_POLAR_ENV=production

# Get your Organization ID from https://polar.sh
VITE_POLAR_ORGANIZATION_ID=your-polar-organization-id

# Organization slug for customer portal (e.g., "my-org")
VITE_POLAR_ORG_SLUG=your-org-slug


# Purchase URL for the license (your Polar product page)
VITE_POLAR_PURCHASE_URL=https://polar.sh/your-org/products/your-product

# Axiom logging (optional)
VITE_AXIOM_TOKEN=
VITE_AXIOM_DATASET=backstage-logs
